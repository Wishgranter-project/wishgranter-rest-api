{
    "openapi": "3.0.3",
    "info": {
        "title": "Wishgranter Rest API",
        "description": "This describes a restful API for a web-based music player. This is part of the [Wishgranter project](https://github.com/orgs/Wishgranter-project).",
        "version": "1.0"
    },
    "servers": [
        {
            "url": "https://api.server.test/v1"
        }
    ],
    "tags": [
        {
            "name": "playlists",
            "description": "Everything about your playlists"
        },
        {
            "name": "playlistItems",
            "description": "Everything about your playlist items"
        },
        {
            "name": "user",
            "description": "Everything about the users"
        }
    ],
    "components": {
        "parameters": {
            "userId": {
                "name": "user-id",
                "description": "The user's unique id.",
                "in": "path",
                "schema": {
                    "type": "string"
                },
                "required": true,
                "example": "johnny-silverhand"
            },
            "playlistId": {
                "name": "playlist-id",
                "description": "A playlist id withing a collection.",
                "in": "path",
                "schema": {
                    "type": "string"
                },
                "required": true,
                "example": "samurais-best"
            },
            "itemsPerPage": {
                "name": "itemsPerPage",
                "description": "The maximum number of items to present per page.",
                "in": "query",
                "schema": {
                    "type": "integer"
                },
                "required": false,
                "example": 20
            },
            "page": {
                "name": "page",
                "description": "The page we are aiming for",
                "in": "query",
                "schema": {
                    "type": "integer"
                },
                "example": 1
            }
        },
        "schemas": {
            "baseMessage": {
                "type": "object",
                "description": "A generic message object.",
                "properties": {
                    "type": {
                        "description": "Type of the message",
                        "type": "string",
                        "enum": [
                            "success",
                            "error",
                            "warning",
                            "info"
                        ]
                    },
                    "code": {
                        "type": "integer",
                        "description": "Machine code associated to the message, like an error code for example."
                    },
                    "title": {
                        "type": "string",
                        "description": "Short summary."
                    },
                    "description": {
                        "type": "string",
                        "description": "A human-readable description of the message."
                    }
                }
            },
            "messageNothingFound": {
                "allOf": [
                    {
                        "$ref": "#/components/schemas/baseMessage"
                    },
                    {
                        "type": "object",
                        "properties": {
                            "type": {
                                "example": "error"
                            },
                            "code": {
                                "example": 404
                            },
                            "title": {
                                "example": "Not found."
                            },
                            "description": {
                                "example": "We could not find what you are looking for."
                            }
                        }
                    }
                ]
            },
            "messageAccessDenied": {
                "allOf": [
                    {
                        "$ref": "#/components/schemas/baseMessage"
                    },
                    {
                        "type": "object",
                        "properties": {
                            "type": {
                                "example": "error"
                            },
                            "code": {
                                "example": 403
                            },
                            "title": {
                                "example": "Access denied."
                            },
                            "description": {
                                "example": "You are not authorized to access this resource."
                            }
                        }
                    }
                ]
            },
            "messageInvalidParameter": {
                "allOf": [
                    {
                        "$ref": "#/components/schemas/baseMessage"
                    },
                    {
                        "type": "object",
                        "properties": {
                            "type": {
                                "example": "error"
                            },
                            "code": {
                                "example": 400
                            },
                            "title": {
                                "example": "Invalid parameter."
                            },
                            "description": {
                                "example": "Parameter X must be type Y."
                            }
                        }
                    }
                ]
            },
            "basePlaylist": {
                "type": "object",
                "description": "Describes a playlist object",
                "properties": {
                    "title": {
                        "type": "string",
                        "description": "The human-readable title of the playlist.",
                        "example": "Samurai's best"
                    },
                    "description": {
                        "type": "string",
                        "description": "The human-readable description.",
                        "example": "Samurai's all time bangers."
                    }
                }
            },
            "playlist": {
                "allOf": [
                    {
                        "$ref": "#/components/schemas/basePlaylist"
                    },
                    {
                        "type": "object",
                        "description": "Describes a playlist object",
                        "properties": {
                            "id": {
                                "type": "string",
                                "description": "The playlist id",
                                "example": "samurais-best"
                            }
                        }
                    }
                ]
            },
            "playableItem": {
                "type": "object",
                "description": "A description of a playable item, a music or an album.",
                "properties": {
                    "title": {
                        "type": "string",
                        "description": "The music's title.",
                        "example": "Black dog"
                    },
                    "artist": {
                        "type": "array",
                        "description": "The performing artist(s).",
                        "example": ["Samurai"],
                        "items": {
                          "type": "string"
                        }
                    },
                    "featuring": {
                        "type": "array",
                        "description": "Featured artist(s).",
                        "items": {
                          "type": "string"
                        }
                    },
                    "cover": {
                        "type": "string",
                        "description": "The original artist if the music is being performed by someone else."
                    },
                    "album": {
                        "type": "string",
                        "description": "The album's title."
                    },
                    "soundtrack": {
                        "type": "array",
                        "description": "An intellectual property featuring the music.",
                        "items": {
                          "type": "string"
                        }
                    },
                    "genre": {
                        "type": "array",
                        "description": "Musical genre(s) the item belongs to.",
                        "items": {
                          "type": "string"
                        }
                    },
                    "xxx": {
                        "type": "string",
                        "description": ""
                    }
                }
            },
            "playlistItem": {
                "allOf": [
                    {
                        "$ref": "#/components/schemas/playableItem"
                    },
                    {
                        "type": "object",
                        "description": "A playable item saved within a playlist.",
                        "properties": {
                            "uuid": {
                                "type": "string",
                                "description": "An unique identifier."
                            }
                        }
                    }
                ]
            },
            "page": {
                "type": "object",
                "description": "Describes a set of item within a set, a page.",
                "properties": {
                    "meta": {
                        "description": "Meta data about the pagination.",
                        "type": "object",
                        "properties": {
                            "total": {
                                "type": "integer",
                                "description": "The total number of items to be listed.",
                                "example": 100
                            },
                            "itemsPerPage": {
                                "type": "integer",
                                "description": "Maximum number of items a page may contain.",
                                "example": 10
                            },
                            "pages": {
                                "type": "integer",
                                "description": "How many pages there are.",
                                "example": 10
                            },
                            "page": {
                                "type": "integer",
                                "description": "The current page.",
                                "example": 1
                            },
                            "count": {
                                "type": "integer",
                                "description": "Number of items within this set, this page. Naturally equal or less than itemsPerPage",
                                "example": 10
                            }
                        }
                    },
                    "data": {
                        "description": "The actual list of items.",
                        "type": "array",
                        "items": {

                        }
                    }
                }
            }
        },
        "responses": {
            "accessDenied": {
                "description": "Access denied",
                "content": {
                    "application/json": {
                        "schema": {
                            "properties": {
                                "messages": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/messageAccessDenied"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "notFound": {
                "description": "Not found",
                "content": {
                    "application/json": {
                        "schema": {
                            "properties": {
                                "messages": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/messageNothingFound"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "invalidData": {
                "description": "Invalid data",
                "content": {
                    "application/json": {
                        "schema": {
                            "properties": {
                                "messages": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/messageInvalidParameter"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "securitySchemes": {
            "cookieAuthentication": {
                "type": "apiKey",
                "in": "cookie",
                "name": "sessionId"
            }
        }
    },
    "paths": {
        "/api/v1/user/{user-id}/collection/playlists/{playlist-id}/download": {
            "get": {
                "operationId": "downloadPlaylist",
                "tags": [
                    "playlists"
                ],
                "summary": "Download playlist.",
                "description": "Downloads the specified playlist.",
                "security": [
                    {
                        "cookieAuthentication": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/userId"
                    },
                    {
                        "$ref": "#/components/parameters/playlistId"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "headers": {
                            "content-type": {
                                "description": "Mime type",
                                "example": "application/jsonl",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "content-disposition": {
                                "description": "Content disposition",
                                "example": "attachment; filename=\"playlist-name.dpls\"",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            
                        }
                    },
                    "403": {
                        "$ref": "#/components/responses/accessDenied"
                    },
                    "404": {
                        "$ref": "#/components/responses/notFound"
                    }
                }
            }
        },
        "/api/v1/user/{user-id}/collection/playlists/{playlist-id}": {
            "get": {
                "operationId": "getPlaylist",
                "tags": [
                    "playlists"
                ],
                "summary": "Retrieves a playlist.",
                "description": "Returns a single playlist.",
                "security": [
                    {
                        "cookieAuthentication": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/userId"
                    },
                    {
                        "$ref": "#/components/parameters/playlistId"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                          "application/json": {
                            "schema": {
                              "properties": {
                                "data": {
                                  "$ref": "#/components/schemas/playlist"
                                }
                              }
                            }
                          }
                        }
                    },
                    "403": {
                        "$ref": "#/components/responses/accessDenied"
                    },
                    "404": {
                        "$ref": "#/components/responses/notFound"
                    }
                }
            },
            "put": {
                "operationId": "updatePlaylist",
                "tags": [
                    "playlists"
                ],
                "summary": "Update playlist.",
                "description": "Updates the specified playlist.",
                "security": [
                    {
                        "cookieAuthentication": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/userId"
                    },
                    {
                        "$ref": "#/components/parameters/playlistId"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/basePlaylist"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "messages": {
                                            "type": "array",
                                            "items": {
                                                "allOf": [
                                                    {
                                                        "$ref": "#/components/schemas/baseMessage"
                                                    },
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "example": "success"
                                                            },
                                                            "code": {
                                                                "example": 200
                                                            },
                                                            "title": {
                                                                "example": "Success."
                                                            },
                                                            "description": {
                                                                "example": "The playlist has been updated."
                                                            }
                                                        }
                                                    }
                                                ]
                                            }
                                        },
                                        "data": {
                                            "$ref": "#/components/schemas/playlist"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/invalidData"
                    },
                    "403": {
                        "$ref": "#/components/responses/accessDenied"
                    },
                    "404": {
                        "$ref": "#/components/responses/notFound"
                    }
                }
            },
            "delete": {
                "operationId": "deletePlaylist",
                "tags": [
                    "playlists"
                ],
                "summary": "Delete playlist.",
                "description": "Deletes the specified playlist.",
                "security": [
                    {
                        "cookieAuthentication": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/userId"
                    },
                    {
                        "$ref": "#/components/parameters/playlistId"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "messages": {
                                            "type": "array",
                                            "items": {
                                                "allOf": [
                                                    {
                                                        "$ref": "#/components/schemas/baseMessage"
                                                    },
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "example": "success"
                                                            },
                                                            "code": {
                                                                "example": 201
                                                            },
                                                            "title": {
                                                                "example": "Deleted."
                                                            },
                                                            "description": {
                                                                "example": "Playlist deleted."
                                                            }
                                                        }
                                                    }
                                                ]
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "403": {
                        "$ref": "#/components/responses/accessDenied"
                    },
                    "404": {
                        "$ref": "#/components/responses/notFound"
                    }
                }
            }
        },
        "/api/v1/user/{user-id}/collection/playlists": {
            "get": {
                "operationId": "listPlaylists",
                "tags": [
                    "playlists"
                ],
                "summary": "List playlists.",
                "description": "Returns a list of playlists belonging to the specified user.",
                "security": [
                    {
                        "cookieAuthentication": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/userId"
                    },
                    {
                        "$ref": "#/components/parameters/itemsPerPage"
                    },
                    {
                        "$ref": "#/components/parameters/page"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                  "allOf": [
                                      {
                                        "$ref": "#/components/schemas/page"
                                      },
                                      {
                                        "type": "object",
                                        "properties": {
                                            "data": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/playlist"
                                                }
                                            }
                                        }
                                      }
                                  ]
                                }
                            }
                        }
                    },
                    "403": {
                        "$ref": "#/components/responses/accessDenied"
                    }
                }
            },
            "post": {
                "operationId": "createNewPlaylist",
                "tags": [
                    "playlists"
                ],
                "summary": "Create new playlist.",
                "description": "Creates a new playlist for the user's collection.",
                "security": [
                    {
                        "cookieAuthentication": []
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/basePlaylist"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "messages": {
                                            "type": "array",
                                            "items": {
                                                "allOf": [
                                                    {
                                                        "$ref": "#/components/schemas/baseMessage"
                                                    },
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "example": "success"
                                                            },
                                                            "code": {
                                                                "example": 201
                                                            },
                                                            "title": {
                                                                "example": "Success."
                                                            },
                                                            "description": {
                                                                "example": "A new playlist has been created."
                                                            }
                                                        }
                                                    }
                                                ]
                                            }
                                        },
                                        "data": {
                                            "$ref": "#/components/schemas/playlist"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/invalidData"
                    },
                    "403": {
                        "$ref": "#/components/responses/accessDenied"
                    }
                }
            }
        },
        "/api/v1/user/{user-id}/collection/items": {
            "post": {
                "operationId": "createNewPlaylistItem",
                "tags": [
                    "playlistItems"
                ],
                "summary": "Create new playlist item.",
                "description": "Creates a new playlist item for the user's collection.",
                "security": [
                    {
                        "cookieAuthentication": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/userId"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "allOf": [
                                    {
                                        "type": "object",
                                        "properties": {
                                            "playlistId": {
                                                "type": "string",
                                                "description": "The id of the playlist we are to add the item to."
                                            }
                                        }
                                    },
                                    {
                                        "$ref": "#/components/schemas/playableItem"
                                    }
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "messages": {
                                            "type": "array",
                                            "items": {
                                                "allOf": [
                                                    {
                                                        "$ref": "#/components/schemas/baseMessage"
                                                    },
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "example": "success"
                                                            },
                                                            "code": {
                                                                "example": 201
                                                            },
                                                            "title": {
                                                                "example": "Success."
                                                            },
                                                            "description": {
                                                                "example": "New item added to your playlist."
                                                            }
                                                        }
                                                    }
                                                ]
                                            }
                                        },
                                        "data": {
                                            "$ref": "#/components/schemas/playlistItem"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "403": {
                        "$ref": "#/components/responses/accessDenied"
                    },
                    "400": {
                        "$ref": "#/components/responses/invalidData"
                    }
                }
            }
        }
    }
}