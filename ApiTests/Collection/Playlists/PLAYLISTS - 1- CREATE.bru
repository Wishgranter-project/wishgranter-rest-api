meta {
  name: PLAYLISTS - 1: CREATE
  type: http
  seq: 1
}

post {
  url: {{base_url}}/test/api/v1/users/adinan/collection/playlists
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  title: Random name for a playlist
  description: This is the playlist's description.
}

assert {
  res.status: eq 201
}

settings {
  encodeUrl: true
  timeout: 0
}
