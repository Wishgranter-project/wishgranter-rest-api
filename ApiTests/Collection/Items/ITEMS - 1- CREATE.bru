meta {
  name: ITEMS - 1: CREATE
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/users/adinan/collection/items
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  title: music title
  playlist: music-metal
}

assert {
  res.status: eq 201
}

settings {
  encodeUrl: true
  timeout: 0
}
