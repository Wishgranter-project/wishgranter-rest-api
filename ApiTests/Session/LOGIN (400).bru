meta {
  name: LOGIN (400)
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/v1/session
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  username: {{$randomUserName}}
  password: {{$randomPassword}}
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  Example of what a failed login attempt looks lile.
  
}
